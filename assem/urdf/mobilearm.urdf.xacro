<?xml version="1.0" encoding="utf-8"?>
<robot name="mobilearm" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="mobilearm" params="prefix:= ''">

    <xacro:property name="basex" value="0"/>
    <xacro:property name="basey" value="0"/>
    <xacro:property name="basez" value="0.16124"/>

    <link name="${prefix}base_link">
      <inertial>
        <origin
          xyz="${-0.21394 + basex} ${-0.22654 + basey} ${0.74485 + basez}"
          rpy="0 0 0" />
        <mass value="0.56" />
        <inertia
          ixx="0.0013214"
          ixy="-8.558E-07"
          ixz="2.1239E-05"
          iyy="0.00253"
          iyz="3.1E-08"
          izz="0.0036853" />
      </inertial>
      <visual>
        <origin xyz="${basex} ${basey} ${basez}" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://assem/meshes/base_link.STL" />
        </geometry>
        <material name="">
          <color rgba="0.79216 0.81961 0.93333 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="${basex} ${basey} ${basez}" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://assem/meshes/base_link.STL" />
        </geometry>
      </collision>
    </link>

    <link name="${prefix}link_1">
      <inertial>
        <origin
          xyz="${0.0046512 + basex} ${-0.00016132 + basey} ${0.072563 + basez}"
          rpy="0 0 0" />
        <mass value="0.4363" />
        <inertia
          ixx="0.00020623"
          ixy="1.769E-09"
          ixz="2.6559E-08"
          iyy="0.00025574"
          iyz="1.5643E-05"
          izz="0.00020704" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://assem/meshes/link_1.STL" />
        </geometry>
        <material name="">
          <color rgba="0.79216 0.81961 0.93333 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="${basex} ${basey} ${basez}" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://assem/meshes/link_1.STL" />
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}joint_1" type="revolute">
      <origin
        xyz="${0 + basex} ${0 + basey} ${0.12509 + basez}"
        rpy="0 0 0" />
      <parent link="${prefix}base_link" />
      <child link="${prefix}link_1" />
      <axis xyz="0 0 1" />
      <limit lower="0" upper="3.142" effort="3.75" velocity="3" />
      <dynamics damping="0.25" friction="0.12" />
    </joint>

    <link name="${prefix}link_2">
      <inertial>
        <origin
          xyz="${-0.11444 + basex} ${-0.014193 + basey} ${0.060343 + basez}"
          rpy="0 0 0" />
        <mass value="0.39896" />
        <inertia
          ixx="0.0017229"
          ixy="-1.3499E-08"
          ixz="-9.8954E-07"
          iyy="0.0018259"
          iyz="-7.959E-06"
          izz="0.00012156" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://assem/meshes/link_2.STL" />
        </geometry>
        <material name="">
          <color rgba="0.79216 0.81961 0.93333 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="${basex} ${basey} ${basez}" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://assem/meshes/link_2.STL" />
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}joint_2" type="revolute">
      <origin xyz="0 0.030 0" rpy="1.5708 -1.5708 3.1416" />
      <parent link="${prefix}link_1" />
      <child link="${prefix}link_2" />
      <axis xyz="0 0 1" />
      <limit lower="-1.57" upper="1.57" effort="13.78" velocity="3" />
      <dynamics damping="0.25" friction="0.12" />
    </joint>

    <link name="${prefix}link_3">
      <inertial>
        <origin
          xyz="${-0.11446 + basex} ${0.013922 + basey} ${0.059262 + basez}"
          rpy="0 0 0" />
        <mass value="0.39896" />
        <inertia
          ixx="0.0017363"
          ixy="-1.2616E-08"
          ixz="9.8973E-07"
          iyy="0.0018392"
          iyz="7.7138E-06"
          izz="0.00012191" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://assem/meshes/link_3.STL" />
        </geometry>
        <material name="">
          <color rgba="0.79216 0.81961 0.93333 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="${basex} ${basey} ${basez}" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://assem/meshes/link_3.STL" />
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}joint_3" type="revolute">
      <origin xyz="0.22889 0 -0.030" rpy="0 0 0" />
      <parent link="${prefix}link_2" />
      <child link="${prefix}link_3" />
      <axis xyz="0 0 1" />
      <limit lower="-2.7" upper="2.7" effort="3.22" velocity="3" />
      <dynamics damping="0.25" friction="0.12" />
    </joint>

    <link name="${prefix}link4">
      <inertial>
        <origin
          xyz="${-0.021077 + basex} ${0.0046839 + basey} ${0.023249 + basez}"
          rpy="0 0 0" />
        <mass value="0.26777" />
        <inertia
          ixx="0.00036674"
          ixy="1.8133E-07"
          ixz="-4.2166E-07"
          iyy="0.00026014"
          iyz="0.00010237"
          izz="0.00024593" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://assem/meshes/link4.STL" />
        </geometry>
        <material name="">
          <color rgba="0.79216 0.81961 0.93333 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="${basex} ${basey} ${basez}" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://assem/meshes/link4.STL" />
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}joint_4" type="revolute">
      <origin xyz="0.22889 0 0" rpy="0 0 0" />
      <parent link="${prefix}link_3" />
      <child link="${prefix}link4" />
      <axis xyz="0 0 1" />
      <limit lower="-2.7" upper="2.7" effort="3.22" velocity="3" />
      <dynamics damping="0.25" friction="0.12" />
    </joint>

    <link name="${prefix}ee_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.0005 0.0005 0.0005"/>
        </geometry>
        <material name="red">
          <color rgba="1 0 0 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.0005 0.0005 0.0005"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}link4_to_ee" type="fixed">
      <parent link="${prefix}link4"/>
      <child link="${prefix}ee_link"/>
      <origin xyz="0.13156 0 0.00906" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}link_5">
      <inertial>
        <origin
          xyz="${-0.0055585 + basex} ${0.010517 + basey} ${0.011053 + basez}"
          rpy="0 0 0" />
        <mass value="0.006514" />
        <inertia
          ixx="8.6032E-07"
          ixy="7.3952E-08"
          ixz="2.0887E-08"
          iyy="5.9497E-07"
          iyz="-1.4827E-07"
          izz="6.7802E-07" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://assem/meshes/link_5.STL" />
        </geometry>
        <material name="">
          <color rgba="0.25098 0.25098 0.25098 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="${basex} ${basey} ${basez}" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://assem/meshes/link_5.STL" />
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}joint_5" type="prismatic">
      <origin xyz="0.13156 0 0.00906" rpy="0 0 0" />
      <parent link="${prefix}link4" />
      <child link="${prefix}link_5" />
      <axis xyz="0 0 1" />
      <limit lower="0" upper="0.014965" effort="1.15" velocity="2" />
      <dynamics damping="0.25" friction="0.12" />
    </joint>

    <link name="${prefix}link_5_5">
      <inertial>
        <origin
          xyz="${-0.0055707 + basex} ${0.010386 + basey} ${0.010964 + basez}"
          rpy="0 0 0" />
        <mass value="0.0065475" />
        <inertia
          ixx="8.8468E-07"
          ixy="7.193E-08"
          ixz="1.9515E-08"
          iyy="6.077E-07"
          iyz="-1.5978E-07"
          izz="7.0061E-07" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://assem/meshes/link_5_5.STL" />
        </geometry>
        <material name="">
          <color rgba="0.25098 0.25098 0.25098 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="${basex} ${basey} ${basez}" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://assem/meshes/link_5_5.STL" />
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}joint_5_5" type="prismatic">
      <origin xyz="0.13156 0 0.00906" rpy="0 0 0" />
      <parent link="${prefix}link4" />
      <child link="${prefix}link_5_5" />
      <axis xyz="0 0 1" />
      <limit lower="-0.014965" upper="0" effort="1.15" velocity="2" />
      <dynamics damping="0.25" friction="0.12" />
    </joint>

  </xacro:macro>

</robot>